# Demo-only settings for `abra demo` or `go run ./cmd/abra demo`.
# This uses deterministic local embeddings and a fixed token so a new user can
# try Abra without signing up for an embedding provider.
ABRA_API_KEYS=dev-token
ABRA_API_TOKEN=dev-token
ABRA_APPROVAL_MODE=advisory
ABRA_PORT=18080
POSTGRES_PORT=5433
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=embedding-model-1536
EMBEDDING_DIMENSIONS=1536
ALLOW_LOCAL_EMBEDDINGS_IN_PRODUCTION=true
REDACT_PII=true
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=1 minute
WORKER_INTERVAL=1s
ABRA_DEPLOYMENT_ENVIRONMENT=development
