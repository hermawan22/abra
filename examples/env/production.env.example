# Copy this file to .env.production and replace every placeholder before exposing Abra.
NODE_ENV=production
ABRA_API_KEYS=replace-with-generated-token
ABRA_APPROVAL_MODE=enforce

# Default production examples use a compatible embedding endpoint. For a
# single-host offline install, run `abra models up` and set EMBEDDING_PROVIDER=local
# with EMBEDDING_BASE_URL=http://host.docker.internal:8080/v1.
EMBEDDING_PROVIDER=compatible
EMBEDDING_BASE_URL=https://embedding-provider.example/v1
EMBEDDING_API_KEY=replace-with-embedding-key
EMBEDDING_MODEL=embedding-model
EMBEDDING_DIMENSIONS=1024
EMBEDDING_TIMEOUT=30s
RERANKER_PROVIDER=
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=
ALLOW_LOCAL_EMBEDDINGS_IN_PRODUCTION=false

REDACT_PII=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
ABRA_PORT=18080

# Optional: use managed Postgres instead of the Compose Postgres service.
# ABRA_DATABASE_URL=postgres://user:password@host:5432/abra

# Optional OpenTelemetry tracing over OTLP HTTP.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# ABRA_TRACING_SAMPLE_RATIO=0.25
# ABRA_TRACING_INSECURE=false
# ABRA_SERVICE_NAME=abra
# ABRA_DEPLOYMENT_ENVIRONMENT=production
