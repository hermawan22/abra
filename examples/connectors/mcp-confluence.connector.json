{
  "id": "confluence-platform",
  "name": "Platform Confluence",
  "scope": "team:platform",
  "mcp_url": "https://mcp.example.internal/mcp",
  "tool": "export_documents",
  "arguments": {
    "space": "ENG",
    "limit": 50
  },
  "connector_kind": "confluence",
  "document_source_type": "confluence",
  "bearer_token_env": "CONFLUENCE_MCP_TOKEN",
  "header_env": {
    "X-Tenant-ID": "CONFLUENCE_TENANT_ID"
  },
  "status": "active",
  "authority": "team-convention",
  "authority_score": 0.7,
  "freshness_seconds": 600,
  "schedule": "@every 10m",
  "verify_query": "platform runbook",
  "metadata": {
    "owner": "platform",
    "connector_model": "user_owned_mcp"
  }
}
